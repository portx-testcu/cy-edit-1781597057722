<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns="http://camel.apache.org/schema/spring" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <route id="mockRoute">
        <from uri="direct:mockRouteURI"/>

        <log message="MOCK: Mocking route ${header.CamelInterceptedEndpoint} ${headers}" loggingLevel="DEBUG"/>
        <choice>
            <when>
                <simple>${header.CamelHttpPath} regex '^.*/templates.*'</simple>
                <log message="Mocking Pulumi get templates" loggingLevel="DEBUG"/>
                <setBody>
                    <constant>resource:classpath:test-data/pulumiGetTemplatesResponse.json</constant>
                </setBody>
            </when>
        </choice>

    </route>
</routes>